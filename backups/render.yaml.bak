services:
  - type: web
    name: titanium-ai-saas
    env: python
    plan: free

    buildCommand: |
      pip install --upgrade pip
      pip install -r requirements.txt

    startCommand: |
      gunicorn production_stack.backend.app:app \
      -k uvicorn.workers.UvicornWorker \
      --bind 0.0.0.0:10000 \
      --workers 2 \
      --timeout 120

    envVars:
      - key: PYTHON_VERSION
        value: 3.13.0

      - key: PORT
        value: 10000

      - key: ENVIRONMENT
        value: production

      - key: PYTHONUNBUFFERED
        value: true

      - key: WEB_CONCURRENCY
        value: 2
